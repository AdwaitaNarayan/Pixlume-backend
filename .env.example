# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://pixlume_user:yourpassword@localhost:5432/pixlume_db

# ── Admin ────────────────────────────────────────────────────────────────────
# Static API key for admin endpoints – change this!
ADMIN_API_KEY=change-me-super-secret

# ── AWS S3 (used when CLOUDINARY_URL is not set) ────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# ── Cloudinary (takes priority over S3 when set) ────────────────────────────
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=
