# ── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://pixlume_user:yourpassword@localhost:5432/pixlume_db

# ── Admin Authentication ─────────────────────────────────────────────────────
# JWT Secret Key (generate a strong random string)
SECRET_KEY=generate_a_secure_random_string_here
# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AWS S3 (used when CLOUDINARY_URL is not set) ────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key-id
AWS_SECRET_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# ── Cloudinary (takes priority over S3 when set) ────────────────────────────
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. For production, add your frontend URL.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
